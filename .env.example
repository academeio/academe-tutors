# =============================================================================
# Academe Tutors — Environment Configuration
# Copy to .env and fill in values
# =============================================================================

# --- Database (Shared Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# --- LTI 1.3 ---
LTI_ISSUER=https://sbvlms.cloudintegral.com
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=
LTI_OIDC_AUTH_URL=https://sbvlms.cloudintegral.com/api/lti/authorize_redirect
LTI_JWKS_URL=https://sbvlms.cloudintegral.com/api/lti/security/jwks
LTI_TOKEN_URL=https://sbvlms.cloudintegral.com/login/oauth2/token

# --- AI Providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=           # For embeddings (text-embedding-3-large)

# --- Embedding ---
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# --- Application ---
BACKEND_PORT=8001
FRONTEND_PORT=3782
SECRET_KEY=               # For session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
ALLOWED_ORIGINS=http://localhost:3782,https://sbvlms.cloudintegral.com

# --- Optional: Web Search ---
BRAVE_API_KEY=
