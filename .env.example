# --- Database (Shared Neon PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# --- AI (OpenRouter) ---
